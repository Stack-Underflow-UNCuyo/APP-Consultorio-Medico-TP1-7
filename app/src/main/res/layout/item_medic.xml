<?xml version="1.0" encoding="utf-8"?>

<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="0dp"
    app:cardBackgroundColor="#FFFFFF"
    app:strokeColor="#E0E8F0"
    app:strokeWidth="1dp"
    app:rippleColor="#E8F0FE">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp">

        <TextView
            android:id="@+id/tv_avatar_medico"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:text="A"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#1A73E8"
            android:gravity="center"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent" />


        <TextView
            android:id="@+id/tv_nombre_medico"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Nombre Apellido"
            android:textSize="15sp"
            android:textStyle="bold"
            android:textColor="#0D2B4E"
            app:layout_constraintTop_toTopOf="@+id/tv_avatar_medico"
            app:layout_constraintStart_toEndOf="@+id/tv_avatar_medico"
            app:layout_constraintEnd_toStartOf="@+id/btn_ver_turnos_medico"
            android:layout_marginStart="12dp"
            android:layout_marginEnd="8dp" />


        <TextView
            android:id="@+id/tv_especialidad_matricula"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="DNI 38421567 · 261 5234567"
            android:textSize="12sp"
            android:textColor="#5A7A99"
            app:layout_constraintTop_toBottomOf="@+id/tv_nombre_medico"
            app:layout_constraintStart_toEndOf="@+id/tv_avatar_medico"
            app:layout_constraintEnd_toStartOf="@+id/btn_ver_turnos_medico"
            android:layout_marginStart="12dp"
            android:layout_marginTop="3dp"
            android:layout_marginEnd="8dp" />


        <ImageButton
            android:id="@+id/btn_ver_turnos_medico"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@android:drawable/ic_menu_my_calendar"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Ver turnos"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:tint="#1A73E8" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</com.google.android.material.card.MaterialCardView>