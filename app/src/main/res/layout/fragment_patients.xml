<?xml version="1.0" encoding="utf-8"?>
<!--
    Fragmento: Pacientes
    Ubicación: res/layout/fragment_pacientes.xml
    Muestra: buscador + lista de pacientes registrados
-->
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F0F4F8">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:paddingBottom="80dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- ============================================= -->
            <!--  BUSCADOR                                     -->
            <!-- ============================================= -->

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/til_buscar_paciente"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Buscar paciente..."
                app:boxCornerRadiusTopStart="14dp"
                app:boxCornerRadiusTopEnd="14dp"
                app:boxCornerRadiusBottomStart="14dp"
                app:boxCornerRadiusBottomEnd="14dp"
                app:boxStrokeColor="#1A73E8"
                app:boxBackgroundColor="#FFFFFF"
                app:hintTextColor="#5A7A99"
                app:startIconDrawable="@android:drawable/ic_menu_search"
                app:startIconTint="#5A7A99"
                app:endIconMode="clear_text"
                app:endIconTint="#5A7A99"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                android:layout_marginTop="20dp">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/et_buscar_paciente"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="textPersonName"
                    android:imeOptions="actionSearch"
                    android:singleLine="true"
                    android:textSize="15sp"
                    android:textColor="#0D2B4E" />

            </com.google.android.material.textfield.TextInputLayout>

            <!-- Contador de resultados -->
            <TextView
                android:id="@+id/tv_count_pacientes"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0 pacientes registrados"
                android:textSize="12sp"
                android:textColor="#5A7A99"
                android:layout_marginStart="20dp"
                android:layout_marginTop="10dp"
                android:layout_marginBottom="6dp" />

            <!-- ============================================= -->
            <!--  LISTA DE PACIENTES (RecyclerView)            -->
            <!-- ============================================= -->

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_pacientes"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:clipToPadding="false"
                android:nestedScrollingEnabled="false" />

            <!-- Estado vacío -->
            <LinearLayout
                android:id="@+id/layout_empty_pacientes"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="48dp"
                android:visibility="gone">

                <ImageView
                    android:layout_width="64dp"
                    android:layout_height="64dp"
                    android:src="@android:drawable/ic_menu_myplaces"
                    android:tint="#C5D8EE" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="No hay pacientes registrados"
                    android:textSize="15sp"
                    android:textColor="#5A7A99"
                    android:layout_marginTop="12dp" />

            </LinearLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- FAB: Nuevo paciente -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fab_nuevo_paciente"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_margin="20dp"
        android:contentDescription="Nuevo paciente"
        android:src="@android:drawable/ic_input_add"
        app:backgroundTint="#1A73E8"
        app:tint="#FFFFFF"
        app:elevation="6dp" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>