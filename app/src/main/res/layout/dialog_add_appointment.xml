<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        android:paddingTop="8dp"
        android:paddingBottom="8dp">


        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="20dp">

            <ImageView
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:src="@android:drawable/ic_menu_my_calendar"
                android:background="@drawable/bg_icon_circle"
                android:padding="8dp"
                app:tint="#1A73E8" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginStart="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Nuevo Turno"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="#0D2B4E" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Completá los datos del turno"
                    android:textSize="12sp"
                    android:textColor="#5A7A99"
                    android:layout_marginTop="1dp" />

            </LinearLayout>

        </LinearLayout>


        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="PARTICIPANTES"
            android:textSize="10sp"
            android:textStyle="bold"
            android:textColor="#1A73E8"
            android:letterSpacing="0.12"
            android:layout_marginBottom="10dp" />

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/til_paciente"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Paciente"
            app:boxCornerRadiusTopStart="12dp"
            app:boxCornerRadiusTopEnd="12dp"
            app:boxCornerRadiusBottomStart="12dp"
            app:boxCornerRadiusBottomEnd="12dp"
            app:boxStrokeColor="#1A73E8"
            app:hintTextColor="#1A73E8"
            app:startIconDrawable="@android:drawable/ic_menu_myplaces"
            app:startIconTint="#1A73E8"
            android:layout_marginBottom="12dp">

            <AutoCompleteTextView
                android:id="@+id/actv_paciente"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="none"
                android:textSize="15sp"
                android:textColor="#0D2B4E" />

        </com.google.android.material.textfield.TextInputLayout>


        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/til_medico"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Médico"
            app:boxCornerRadiusTopStart="12dp"
            app:boxCornerRadiusTopEnd="12dp"
            app:boxCornerRadiusBottomStart="12dp"
            app:boxCornerRadiusBottomEnd="12dp"
            app:boxStrokeColor="#1A73E8"
            app:hintTextColor="#1A73E8"
            app:startIconDrawable="@android:drawable/ic_menu_search"
            app:startIconTint="#1A73E8"
            android:layout_marginBottom="16dp">

            <AutoCompleteTextView
                android:id="@+id/actv_medico"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="none"
                android:textSize="15sp"
                android:textColor="#0D2B4E" />

        </com.google.android.material.textfield.TextInputLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#E0E8F0"
            android:layout_marginBottom="16dp" />



        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="FECHA DEL TURNO"
            android:textSize="10sp"
            android:textStyle="bold"
            android:textColor="#1A73E8"
            android:letterSpacing="0.12"
            android:layout_marginBottom="10dp" />


        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="10dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="#FAFCFF"
            app:strokeColor="#E0E8F0"
            app:strokeWidth="1dp">

            <CalendarView
                android:id="@+id/calendar_view"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:dateTextAppearance="@android:style/TextAppearance.Small"
                android:focusable="true"
                android:focusableInTouchMode="true" />

        </com.google.android.material.card.MaterialCardView>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="16dp">

            <ImageView
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:src="@android:drawable/ic_menu_my_calendar"
                app:tint="#1A73E8" />

            <TextView
                android:id="@+id/tv_fecha_seleccionada"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Seleccioná una fecha"
                android:textSize="13sp"
                android:textColor="#5A7A99"
                android:layout_marginStart="6dp" />

        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#E0E8F0"
            android:layout_marginBottom="16dp" />



        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="HORARIO DISPONIBLE"
            android:textSize="10sp"
            android:textStyle="bold"
            android:textColor="#1A73E8"
            android:letterSpacing="0.12"
            android:layout_marginBottom="4dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Tocá un horario para seleccionarlo"
            android:textSize="12sp"
            android:textColor="#5A7A99"
            android:layout_marginBottom="10dp" />

        <!--
            ChipGroup de horarios: singleSelection=true garantiza que solo
            un horario quede seleccionado a la vez.

            Desde Java, leé el horario seleccionado así:
              int checkedId = chipGroupHorarios.getCheckedChipId();
              if (checkedId != View.NO_ID) {
                  Chip chip = chipGroupHorarios.findViewById(checkedId);
                  selectedTime = chip.getText().toString(); // "HH:MM"
              }

            En una versión más avanzada, podés generar estos chips
            dinámicamente desde Java para marcar los slots ya ocupados
            como deshabilitados (chip.setEnabled(false)).
        -->
        <com.google.android.material.chip.ChipGroup
            android:id="@+id/chipgroup_horarios"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:singleSelection="true"
            app:selectionRequired="false">

            <!-- Mañana -->
            <com.google.android.material.chip.Chip
                android:id="@+id/chip_08_00"
                style="@style/Widget.MaterialComponents.Chip.Filter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="08:00"
                android:textSize="12sp" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_08_30"
                style="@style/Widget.MaterialComponents.Chip.Filter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="08:30"
                android:textSize="12sp" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_09_00"
                style="@style/Widget.MaterialComponents.Chip.Filter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="09:00"
                android:textSize="12sp" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_09_30"
                style="@style/Widget.MaterialComponents.Chip.Filter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="09:30"
                android:textSize="12sp" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_10_00"
                style="@style/Widget.MaterialComponents.Chip.Filter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="10:00"
                android:textSize="12sp" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_10_30"
                style="@style/Widget.MaterialComponents.Chip.Filter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="10:30"
                android:textSize="12sp" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_11_00"
                style="@style/Widget.MaterialComponents.Chip.Filter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="11:00"
                android:textSize="12sp" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_11_30"
                style="@style/Widget.MaterialComponents.Chip.Filter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="11:30"
                android:textSize="12sp" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_14_00"
                style="@style/Widget.MaterialComponents.Chip.Filter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="14:00"
                android:textSize="12sp" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_14_30"
                style="@style/Widget.MaterialComponents.Chip.Filter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="14:30"
                android:textSize="12sp" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_15_00"
                style="@style/Widget.MaterialComponents.Chip.Filter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="15:00"
                android:textSize="12sp" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_15_30"
                style="@style/Widget.MaterialComponents.Chip.Filter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="15:30"
                android:textSize="12sp" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_16_00"
                style="@style/Widget.MaterialComponents.Chip.Filter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="16:00"
                android:textSize="12sp" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_16_30"
                style="@style/Widget.MaterialComponents.Chip.Filter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="16:30"
                android:textSize="12sp" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_17_00"
                style="@style/Widget.MaterialComponents.Chip.Filter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="17:00"
                android:textSize="12sp" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_17_30"
                style="@style/Widget.MaterialComponents.Chip.Filter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="17:30"
                android:textSize="12sp" />

        </com.google.android.material.chip.ChipGroup>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="8dp">

            <ImageView
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:src="@android:drawable/ic_menu_recent_history"
                app:tint="#1A73E8" />

            <TextView
                android:id="@+id/tv_hora_seleccionada"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Seleccioná un horario"
                android:textSize="13sp"
                android:textColor="#5A7A99"
                android:layout_marginStart="6dp" />

        </LinearLayout>

    </LinearLayout>

</androidx.core.widget.NestedScrollView>