<?xml version="1.0" encoding="utf-8"?>
<!--
    Dialog: Nuevo Paciente
    Ubicación: res/layout/dialog_nuevo_paciente.xml
    Usado por: PacientesFragment.java con MaterialAlertDialogBuilder
-->
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        android:paddingTop="8dp"
        android:paddingBottom="8dp">

        <!-- ============================================= -->
        <!--  ENCABEZADO DEL DIALOG                        -->
        <!-- ============================================= -->

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="20dp">

            <!-- Ícono decorativo -->
            <ImageView
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:src="@android:drawable/ic_menu_myplaces"
                android:tint="#1A73E8"
                android:background="@drawable/bg_icon_circle"
                android:padding="8dp" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginStart="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Nuevo Paciente"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="#0D2B4E" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Completá los datos del paciente"
                    android:textSize="12sp"
                    android:textColor="#5A7A99"
                    android:layout_marginTop="1dp" />

            </LinearLayout>

        </LinearLayout>

        <!-- ============================================= -->
        <!--  SECCIÓN: Datos personales                    -->
        <!-- ============================================= -->

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="DATOS PERSONALES"
            android:textSize="10sp"
            android:textStyle="bold"
            android:textColor="#1A73E8"
            android:letterSpacing="0.12"
            android:layout_marginBottom="10dp" />

        <!-- Nombre -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/til_dialog_name"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Nombre"
            app:boxCornerRadiusTopStart="12dp"
            app:boxCornerRadiusTopEnd="12dp"
            app:boxCornerRadiusBottomStart="12dp"
            app:boxCornerRadiusBottomEnd="12dp"
            app:boxStrokeColor="#1A73E8"
            app:hintTextColor="#1A73E8"
            app:startIconDrawable="@android:drawable/ic_menu_edit"
            app:startIconTint="#1A73E8"
            android:layout_marginBottom="12dp">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/et_dialog_name"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="textPersonName|textCapWords"
                android:imeOptions="actionNext"
                android:singleLine="true"
                android:textColor="#0D2B4E"
                android:textSize="15sp" />

        </com.google.android.material.textfield.TextInputLayout>

        <!-- Apellido -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/til_dialog_lastname"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Apellido"
            app:boxCornerRadiusTopStart="12dp"
            app:boxCornerRadiusTopEnd="12dp"
            app:boxCornerRadiusBottomStart="12dp"
            app:boxCornerRadiusBottomEnd="12dp"
            app:boxStrokeColor="#1A73E8"
            app:hintTextColor="#1A73E8"
            app:startIconDrawable="@android:drawable/ic_menu_edit"
            app:startIconTint="#1A73E8"
            android:layout_marginBottom="16dp">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/et_dialog_lastname"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="textPersonName|textCapWords"
                android:imeOptions="actionNext"
                android:singleLine="true"
                android:textColor="#0D2B4E"
                android:textSize="15sp" />

        </com.google.android.material.textfield.TextInputLayout>

        <!-- Divisor -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#E0E8F0"
            android:layout_marginBottom="16dp" />

        <!-- ============================================= -->
        <!--  SECCIÓN: Identificación y contacto           -->
        <!-- ============================================= -->

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="IDENTIFICACIÓN Y CONTACTO"
            android:textSize="10sp"
            android:textStyle="bold"
            android:textColor="#1A73E8"
            android:letterSpacing="0.12"
            android:layout_marginBottom="10dp" />

        <!-- DNI -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/til_dialog_dni"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="DNI"
            app:boxCornerRadiusTopStart="12dp"
            app:boxCornerRadiusTopEnd="12dp"
            app:boxCornerRadiusBottomStart="12dp"
            app:boxCornerRadiusBottomEnd="12dp"
            app:boxStrokeColor="#1A73E8"
            app:hintTextColor="#1A73E8"
            app:startIconDrawable="@android:drawable/ic_menu_agenda"
            app:startIconTint="#1A73E8"
            app:helperText="Sin puntos. Ej: 38421567"
            app:helperTextTextColor="#5A7A99"
            android:layout_marginBottom="12dp">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/et_dialog_dni"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="number"
                android:maxLength="8"
                android:imeOptions="actionNext"
                android:singleLine="true"
                android:textColor="#0D2B4E"
                android:textSize="15sp" />

        </com.google.android.material.textfield.TextInputLayout>

        <!-- Teléfono -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/til_dialog_phone"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Teléfono celular"
            app:boxCornerRadiusTopStart="12dp"
            app:boxCornerRadiusTopEnd="12dp"
            app:boxCornerRadiusBottomStart="12dp"
            app:boxCornerRadiusBottomEnd="12dp"
            app:boxStrokeColor="#1A73E8"
            app:hintTextColor="#1A73E8"
            app:startIconDrawable="@android:drawable/ic_menu_call"
            app:startIconTint="#1A73E8"
            app:helperText="Con código de área. Ej: 2615234567"
            app:helperTextTextColor="#5A7A99"
            android:layout_marginBottom="12dp">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/et_dialog_phone"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="phone"
                android:imeOptions="actionNext"
                android:singleLine="true"
                android:textColor="#0D2B4E"
                android:textSize="15sp" />

        </com.google.android.material.textfield.TextInputLayout>

        <!-- Email -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/til_dialog_email"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Correo electrónico"
            app:boxCornerRadiusTopStart="12dp"
            app:boxCornerRadiusTopEnd="12dp"
            app:boxCornerRadiusBottomStart="12dp"
            app:boxCornerRadiusBottomEnd="12dp"
            app:boxStrokeColor="#1A73E8"
            app:hintTextColor="#1A73E8"
            app:startIconDrawable="@android:drawable/ic_dialog_email"
            app:startIconTint="#1A73E8"
            android:layout_marginBottom="8dp">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/et_dialog_email"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="textEmailAddress"
                android:imeOptions="actionDone"
                android:singleLine="true"
                android:textColor="#0D2B4E"
                android:textSize="15sp" />

        </com.google.android.material.textfield.TextInputLayout>

    </LinearLayout>

</androidx.core.widget.NestedScrollView>